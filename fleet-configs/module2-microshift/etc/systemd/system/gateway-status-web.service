[Unit]
Description=MicroShift Gateway Status Web Dashboard
After=network-online.target edge-config-microshift.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /etc/edge-config/gateway-status-web.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
