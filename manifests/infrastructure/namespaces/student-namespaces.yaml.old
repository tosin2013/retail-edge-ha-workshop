# =============================================================================
# Student Namespaces
# =============================================================================
# This file creates two namespaces per student:
#   1. retail-edge-student-XX - Workload namespace for VMs, services, etc.
#   2. retail-edge-student-XX-udn - Networking namespace for User Defined Networks
#
# NOTE: This is a static file for initial testing with 5 students.
# For production with 50 students, use the generation script:
#   scripts/generate-student-manifests.sh
#
# Or use the Helm chart with dynamic templating.
# =============================================================================

---
# Student 01 - Workload Namespace
apiVersion: v1
kind: Namespace
metadata:
  name: retail-edge-student-01
  labels:
    workshop: retail-edge-ha
    student-id: "01"
    argocd.argoproj.io/instance: retail-edge-ha
  annotations:
    openshift.io/description: "Retail Edge HA Workshop - Student 01"
    openshift.io/display-name: "Retail Edge HA - Student 01"

---
# Student 01 - UDN Namespace
apiVersion: v1
kind: Namespace
metadata:
  name: retail-edge-student-01-udn
  labels:
    workshop: retail-edge-ha
    student-id: "01"
    k8s.ovn.org/primary-user-defined-network: ""
  annotations:
    openshift.io/description: "UDN Namespace for Student 01"

---
